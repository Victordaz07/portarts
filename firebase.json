{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "target": "portarts",
      "source": ".",
      "frameworksBackend": {
        "region": "us-central1"
      },
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
    }
  ]
}
